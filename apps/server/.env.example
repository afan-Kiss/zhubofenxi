DATABASE_URL="file:../data/app.db"
SESSION_SECRET="请替换为随机长字符串-仅保存在服务端"
PORT=4723
HOST=127.0.0.1
NODE_ENV=development
# 浏览器访问地址（多个来源逗号分隔，生产同域可不跨域）
# 示例：http://8.137.126.18,http://xiangyuzhubao.xyz,http://www.xiangyuzhubao.xyz
CORS_ORIGIN=http://localhost:5173
WEB_ORIGIN=http://localhost:5173
COOKIE_SECURE=false

# 平台 Cookie 加密密钥（至少 32 字符，仅服务端保存）
COOKIE_ENCRYPTION_KEY=请替换成32位以上随机字符串

# 下载文件保存目录（相对 apps/server）
DOWNLOAD_DIR=./data/downloads
MAX_DOWNLOAD_SIZE_MB=100

# 直播场次自动导出 sellerId（系统设置未填时使用）
XHS_SELLER_ID=

# 小红书动态签名（xhshow，见 README-WEB.md 或运行 scripts/install-xhs-signer.bat）
XHS_SIGNER_ENABLED=true
XHS_SIGNER_PYTHON=tools/xhs_signer/.venv/Scripts/python.exe
# XHS_SIGNER_SCRIPT=tools/xhs_signer/signer.py

# 运营报表成品缓存 TTL（分钟），默认与经营同步间隔一致
# OPERATIONS_REPORT_CACHE_TTL_MINUTES=180

# 千帆订单详情 URL 模板（可选；不填则使用默认 ark 详情页）
# QIANFAN_ORDER_DETAIL_URL_TEMPLATE=https://ark.xiaohongshu.com/app-order/order/detail/{packageId}

# 总控台 Cookie 中心（优先从此读取四店千帆 Cookie）
CONTROL_SERVER_URL=http://8.137.126.18/control
CONTROL_SERVICE_TOKEN=

# 四店 Cookie 批量上传接口 Token（POST /api/shop-cookies/update）
# 请求头：Authorization: Bearer <token> 或 X-Shop-Cookie-Token: <token>
SHOP_COOKIE_UPLOAD_TOKEN=

# 千帆 Cookie 本地 .env 兜底（可选；系统设置 SQLite 仍为主要本地兜底）
# QIANFAN_COOKIE_SHIYUJU=
# QIANFAN_COOKIE_HETIANYAYU=
# QIANFAN_COOKIE_XIANGYU=
# QIANFAN_COOKIE_XYXIANGYU=

# 维护工具（清空数据、手动预热等），生产环境默认关闭
# ENABLE_MAINTENANCE_TOOLS=true

# 记账系统用户同步（每 180 分钟经营同步时顺带执行；与记账系统同机部署时默认可用）
# JADE_ACCOUNTING_USER_SYNC_ENABLED=true
# JADE_ACCOUNTING_DB_PATH=/www/wwwroot/jade-accounting/apps/server/prisma/data/accounting.db

# 复制为 apps/server/.env 后按 VPS 实际情况修改（勿提交到 Git）

NODE_ENV=production
PORT=3001

# Prisma SQLite（相对 apps/server 目录，部署后持久化在 data/）
DATABASE_URL="file:../data/app.db"

# 可选：用于其他安全用途；登录会话使用 Prisma Session 表 + session_token Cookie
SESSION_SECRET=请替换成随机长字符串

# 浏览器访问地址（开发模式 Vite 代理用；生产同域 3001 可不跨域）
# 花生壳示例：http://25148di1mn10.vicp.fun
# 多个来源可逗号分隔：http://127.0.0.1:3001,http://25148di1mn10.vicp.fun
CORS_ORIGIN=http://25148di1mn10.vicp.fun

# 未配置 HTTPS 时使用 false；配置 HTTPS 后改为 true
COOKIE_SECURE=false

COOKIE_ENCRYPTION_KEY=请替换成32位以上随机字符串
DOWNLOAD_DIR=./data/downloads
MAX_DOWNLOAD_SIZE_MB=100

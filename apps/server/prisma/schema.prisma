  @@index([startedAt])
  @@index([status])
}

/// 四店福袋活动（lucky_draw_id / room_id 超长数字，必须 String）
model XhsLuckyDraw {
  id               String   @id @default(cuid())
  liveAccountId    String
  liveAccountName  String
  luckyDrawId      String
  roomId           String   @default("")
  giftName         String   @default("")
  senderUserId     String?
  senderNickname   String?
  drawStatus       Int?
  winnerCount      Int      @default(0)
  createTime       DateTime?
  startTime        DateTime?
  rawJson          String?
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  winners XhsLuckyWinner[]

  @@unique([liveAccountId, luckyDrawId])
  @@index([liveAccountId])
  @@index([createTime])
  @@index([lastSyncedAt])
}

/// 福袋中奖人（含地址；无地址也保留）
model XhsLuckyWinner {
  id                  String    @id @default(cuid())
  liveAccountId       String
  liveAccountName     String
  luckyDrawId         String
  winnerUserId        String    @default("")
  winnerKey           String
  redId               String?
  winnerNickname      String    @default("")
  avatar              String?
  recipientName       String?
  recipientPhone      String?
  province            String?
  city                String?
  district            String?
  addressDetail       String?
  fullAddress         String?
  hasAddress          Boolean   @default(false)
  addressComplete     Boolean   @default(false)
  addressMissingJson  String    @default("[]")
  firstAddressSeenAt  DateTime?
  winTime             DateTime?
  officialCourier     String?
  officialTrackingNo  String?
  officialShipped     Boolean   @default(false)
  rawJson             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  draw     XhsLuckyDraw      @relation(fields: [liveAccountId, luckyDrawId], references: [liveAccountId, luckyDrawId], onDelete: Cascade)
  shipment LuckyGiftShipment?

  @@unique([liveAccountId, luckyDrawId, winnerKey])
  @@index([liveAccountId])
  @@index([luckyDrawId])
  @@index([winnerUserId])
  @@index([hasAddress, addressComplete])
  @@index([winTime])
}

/// 福袋发货状态（本系统标记；官方物流可覆盖待发）
model LuckyGiftShipment {
  id                   String    @id @default(cuid())
  winnerId             String    @unique
  shipmentStatus       String    @default("no_address")
  shippingStatusSource String    @default("local")
  freightType          String    @default("COLLECT")
  courierCompany       String?
  trackingNo           String?
  markedShippedAt      DateTime?
  markedShippedBy      String?
  shipmentNote         String?
  sfMonthlyFeeCent     Int?
  sfFeeStatus          String    @default("unknown")
  sfFeeQueriedAt       DateTime?
  sfFeeError           String?
  sfFeeTrackingNo      String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  winner XhsLuckyWinner           @relation(fields: [winnerId], references: [id], onDelete: Cascade)
  logs   LuckyGiftShipmentLog[]

  @@index([shipmentStatus])
  @@index([shippingStatusSource])
  @@index([markedShippedAt])
}

/// 福袋发货操作日志
model LuckyGiftShipmentLog {
  id          String   @id @default(cuid())
  shipmentId  String
  winnerId    String
  action      String
  fromStatus  String?
  toStatus    String?
  operatorId  String?
  operatorName String?
  note        String?
  metaJson    String?
  createdAt   DateTime @default(now())

  shipment LuckyGiftShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
  @@index([winnerId])
}

/// 福袋同步元数据（按直播号）
model LuckyGiftSyncMeta {
  id                 String    @id @default(cuid())
  liveAccountId      String    @unique
  liveAccountName    String    @default("")
  lastSyncedAt       DateTime?
  lastSuccessAt      DateTime?
  lastError          String?
  lastTrigger        String?
  drawCount          Int       @default(0)
  winnerCount        Int       @default(0)
  platformTotal      Int?
  fetchedCount       Int?
  dedupedCount       Int?
  detailFailCount    Int       @default(0)
  newDrawCount       Int       @default(0)
  newAddressCount    Int       @default(0)
  statusChangeCount  Int       @default(0)
  updatedAt          DateTime  @updatedAt
  createdAt          DateTime  @default(now())
}

/// 福袋全局同步运行摘要
model LuckyGiftSyncRun {
  id              String    @id @default("default")
  lastSyncedAt    DateTime?
  lastTrigger     String?
  successShopCount Int      @default(0)
  failedShopCount  Int      @default(0)
  failedShopsJson  String   @default("[]")
  newDrawCount     Int      @default(0)
  newAddressCount  Int      @default(0)
  statusChangeCount Int     @default(0)
  summaryJson      String?
  updatedAt        DateTime @updatedAt
}

/// Wave4: 经营数据版本号（热路径内存整数比对，替代反复 MAX(updatedAt)）
model BusinessDataGeneration {
  id                       String   @id @default("default")
  ordersGeneration         Int      @default(1)
  liveSessionsGeneration   Int      @default(1)
  settlementsGeneration    Int      @default(1)
  workbenchGeneration      Int      @default(1)
  timeSearchGeneration     Int      @default(1)
  scheduleGeneration       Int      @default(1)
  manualOverrideGeneration Int      @default(1)
  offlineDealGeneration    Int      @default(1)
  anchorMasterGeneration   Int      @default(1)
  qualityGeneration        Int      @default(1)
  updatedAt                DateTime @updatedAt
}

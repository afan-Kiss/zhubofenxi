generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  passwordHash       String
  /// 管理员可见的登录密码（创建/重置时写入；用户自行改密后清空）
  managedPassword    String?
  role               String
  enabled            Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  passwordChangedAt  DateTime?
  lastLoginAt        DateTime?
  registeredIp       String?
  registeredUserAgent String?
  lastLoginIp        String?
  lastLoginUserAgent String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  sessions           Session[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PlatformCredential {
  id                    String    @id @default(cuid())
  /// 唯一标识；四店官方账号固定为 shopKey：shiyuju / hetianyayu / xiangyu / xyxiangyu
  platformName          String    @unique
  /// 展示名称（如「XY祥钰珠宝」）；非唯一，四店以外可为普通直播号
  displayName           String    @default("")
  cookieEncrypted       String    @default("")
  remark                String?
  enabled               Boolean   @default(true)
  updatedBy             String?
  cookieStatus          String    @default("unknown")
  cookieLastCheckedAt   DateTime?
  cookieLastSuccessAt   DateTime?
  cookieLastFailedAt    DateTime?
  cookieLastErrorCode   String?
  cookieLastErrorMessage String?
  cookieLastFailedApi   String?
  affectedBusinessSync  Boolean   @default(false)
  lastSyncSuccessAt     DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model DownloadConfig {
  id        String   @id @default(cuid())
  type      String   @unique
  name      String
  url       String
  method    String   @default("GET")
  mode      String   @default("direct_url")
  sellerId  String?
  enabled   Boolean  @default(true)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DownloadBatch {
  id           String    @id @default(cuid())
  status       String
  startDate    String
  endDate      String
  createdBy    String?
  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  errorMessage String?
  createdAt    DateTime  @default(now())
  tasks        DownloadTask[]

  @@index([createdBy])
  @@index([createdAt])
}

model DownloadTask {
  id           String         @id @default(cuid())
  type         String
  mode         String?
  batchId      String?
  step         String?
  pipelineMetaJson String?
  apiDebugJson     String?
  xhsTaskId    String?
  status       String
  fileName     String?
  filePath     String?
  fileSize     Int?
  errorMessage String?
  requestId    String?
  durationMs   Int?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdBy    String?
  createdAt    DateTime       @default(now())
  batch        DownloadBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([createdBy])
  @@index([batchId])
}

model OperationLog {
  id          String   @id @default(cuid())
  userId      String?
  username    String?
  role        String?
  action      String
  module      String
  description String
  ip          String?
  userAgent   String?
  path        String?
  method      String?
  requestId   String?
  durationMs  Int?
  metaJson    String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model RefreshJob {
  id               String    @id @default(cuid())
  type             String
  status           String
  preset           String
  startDate        String
  endDate          String
  progress         Int       @default(0)
  currentStep      String    @default("idle")
  currentStepLabel String    @default("等待开始")
  downloadBatchId  String?
  trustStatus      String?
  errorMessage     String?
  startedBy        String?
  startedAt        DateTime?
  finishedAt       DateTime?
  durationMs       Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model ValidationPackage {
  id           String    @id @default(cuid())
  snapshotId   String
  fileName     String
  filePath     String
  fileSize     Int       @default(0)
  status       String
  errorMessage String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  finishedAt   DateTime?

  @@index([snapshotId])
  @@index([status])
  @@index([createdAt])
}

model ReportExport {
  id           String    @id @default(cuid())
  snapshotId   String
  fileName     String
  filePath     String
  fileSize     Int       @default(0)
  status       String
  errorMessage String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  finishedAt   DateTime?

  @@index([snapshotId])
  @@index([status])
  @@index([createdAt])
}

model PageViewLog {
  id              String    @id @default(cuid())
  userId          String
  username        String
  role            String
  page            String
  path            String?
  startedAt       DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int?
  ip              String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([page])
  @@index([startedAt])
}

model XhsSyncJob {
  id                   String    @id @default(cuid())
  type                 String
  status               String
  preset               String
  startDate            String
  endDate              String
  progress             Int       @default(0)
  currentStep          String    @default("idle")
  currentStepLabel     String    @default("等待开始")
  totalRequestCount    Int       @default(0)
  successRequestCount  Int       @default(0)
  failedRequestCount   Int       @default(0)
  orderCount           Int       @default(0)
  liveSessionCount     Int       @default(0)
  pendingCount         Int       @default(0)
  settledCount         Int       @default(0)
  currentPage          Int       @default(0)
  totalPage            Int?
  currentApiKey        String?
  currentApiLabel      String?
  rangeLabel           String?
  errorMessage         String?
  startedBy            String?
  startedAt            DateTime?
  finishedAt           DateTime?
  durationMs           Int?
  refreshJobId         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  rawOrderDetails        XhsRawOrderDetail[]
  rawLiveSessionDetails  XhsRawLiveSessionDetail[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model XhsRawOrder {
  id              String    @id @default(cuid())
  orderId         String?
  packageId       String?
  liveAccountId   String    @default("legacy")
  liveAccountName String?
  orderTime       DateTime?
  buyerId         String?
  rawJson         Json
  syncJobId       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([liveAccountId, packageId])
  @@index([orderId])
  @@index([liveAccountId, orderId])
  @@index([orderTime])
  @@index([buyerId])
}

model XhsRawOrderDetail {
  id        String     @id @default(cuid())
  orderId   String
  rawJson   String
  syncJobId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  syncJob   XhsSyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@unique([orderId])
  @@index([syncJobId])
}

model XhsRawLiveSession {
  id              String    @id
  liveId          String?
  liveName        String?
  liveAccountId   String    @default("legacy")
  liveAccountName String?
  startTime       DateTime?
  endTime         DateTime?
  anchorName      String?
  rawJson         Json
  syncJobId       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([liveId])
  @@index([liveAccountId])
  @@index([startTime])
  @@index([anchorName])
}

model XhsRawLiveSessionDetail {
  id        String     @id @default(cuid())
  sessionId String
  rawJson   String
  syncJobId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  syncJob   XhsSyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@unique([sessionId])
  @@index([syncJobId])
}

model XhsRawPendingSettlement {
  id         String    @id
  settleNo   String?
  packageId  String?
  orderTime  DateTime?
  rawJson    Json
  syncJobId  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([settleNo])
  @@index([packageId])
  @@index([orderTime])
}

model Anchor {
  id                  String                 @id @default(cuid())
  name                String                 @unique
  externalId          String?
  defaultLiveRoomName String?
  color               String?
  enabled             Boolean                @default(true)
  sortOrder           Int                    @default(0)
  /** 系统主播稳定身份，如 YIFAN_MANUAL；普通主播为 null */
  systemKey           String?                @unique
  /** schedule=场次/排班/时段；manual=仅订单手动指定 */
  attributionMode     AnchorAttributionMode  @default(schedule)
  /** 上岗/生效业务日 YYYY-MM-DD（Asia/Shanghai），空=不限制 */
  effectiveFrom       String?
  /** 离岗业务日 YYYY-MM-DD，空=仍有效；区间 [effectiveFrom, effectiveTo] 闭区间按日 */
  effectiveTo         String?
  deletedAt           DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  timeRules           AnchorTimeRule[]
}

enum AnchorAttributionMode {
  schedule
  manual
}

model AnchorTimeRule {
  id            String    @id @default(cuid())
  anchorId      String
  startTime     String
  endTime       String
  enabled       Boolean   @default(true)
  sortOrder     Int       @default(0)
  /** NULL = 历史规则，对全部订单生效；非 NULL = 仅对 effectiveFrom 之后的支付/下单时间生效 */
  effectiveFrom DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  anchor        Anchor    @relation(fields: [anchorId], references: [id], onDelete: Cascade)

  @@index([anchorId])
}

model XhsRawSettledSettlement {
  id         String    @id
  settleNo   String?
  packageId  String?
  orderTime  DateTime?
  settleTime DateTime?
  rawJson    Json
  syncJobId  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([settleNo])
  @@index([packageId])
  @@index([orderTime])
  @@index([settleTime])
}

/// 售后工作台按订单号缓存（退款金额口径）
model XhsAfterSalesWorkbenchCache {
  id                       String    @id @default(cuid())
  liveAccountId            String    @default("legacy")
  orderNo                  String
  packageId                String?
  officialRefundAmountCent Int       @default(0)
  expectedRefundAmountCent Int?
  appliedAmountCent        Int?
  appliedShipFeeAmountCent   Int       @default(0)
  payAmountCent            Int?
  settlementAmountCent     Int?
  refundIncludesFreight    Boolean   @default(false)
  afterSaleReason          String?
  afterSaleStatus          String?
  successReturnCount       Int       @default(0)
  returnsIds               String?
  rawDetail                Json?
  /// 结构化售后类型（不依赖 rawDetail 全量进内存即可统计退货退款）
  hasReturnRefund          Boolean   @default(false)
  hasRefundOnly            Boolean   @default(false)
  returnRefundCount        Int       @default(0)
  refundOnlyCount          Int       @default(0)
  afterSaleType            String?
  returnTypeCodes          String?
  classificationSource     String?
  fetchStatus              String    @default("pending")
  fetchError               String?
  fetchedAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@unique([liveAccountId, orderNo])
  @@index([fetchStatus])
  @@index([liveAccountId])
  @@index([hasReturnRefund])
}

/// 售后工作台补数队列
model XhsAfterSalesWorkbenchQueue {
  id                    String    @id @default(cuid())
  liveAccountId         String    @default("legacy")
  orderNo               String
  status                String    @default("pending")
  /// 累计请求次数（兼容旧字段）
  attempts              Int       @default(0)
  temporaryAttemptCount Int       @default(0)
  permanentFailureCount Int       @default(0)
  errorType             String?
  lastError             String?
  nextAttemptAt         DateTime?
  lastAttemptAt         DateTime?
  completedAt           DateTime?
  runningSince          DateTime?
  /// 原子认领：worker 身份与令牌
  workerId              String?
  claimToken            String?
  claimedAt             DateTime?
  statusChangedAt       DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([liveAccountId, orderNo])
  @@index([status])
  @@index([liveAccountId])
  @@index([status, nextAttemptAt])
  @@index([liveAccountId, status, nextAttemptAt])
}

/// 售后任务状态变更审计（不含 Cookie）
model XhsAfterSalesQueueAudit {
  id                   String   @id @default(cuid())
  liveAccountId        String   @default("legacy")
  orderNo              String
  fromStatus           String?
  toStatus             String
  reason               String?
  errorType            String?
  force                Boolean  @default(false)
  source               String?
  workerId             String?
  claimToken           String?
  cacheStatus          String?
  orderAfterSaleStatus String?
  operator             String?
  createdAt            DateTime @default(now())

  @@index([liveAccountId, createdAt])
  @@index([orderNo])
  @@index([createdAt])
}

/// 店铺售后运行时熔断（跨进程持久化）
model ShopAfterSalesRuntime {
  id                  String    @id @default(cuid())
  liveAccountId       String    @unique
  platformName        String    @default("")
  circuitOpen         Boolean   @default(false)
  circuitReason       String?
  circuitOpenedAt     DateTime?
  circuitNextProbeAt  DateTime?
  consecutiveAuthFail Int       @default(0)
  consecutiveSignFail Int       @default(0)
  consecutiveCooling  Int       @default(0)
  cooldownUntil       DateTime?
  lastSuccessAt       DateTime?
  lastErrorType       String?
  lastErrorMessage    String?
  completedPerMinute  Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([circuitOpen])
}

/// 未完结订单追踪池
model OrderTrackingPool {
  id             String    @id @default(cuid())
  packageId      String
  skuId          String    @default("")
  reasons        String
  status         String    @default("active")
  orderMonth     String?
  lastStatusText String?
  enteredAt      DateTime  @default(now())
  lastCheckedAt  DateTime  @default(now())
  removedAt      DateTime?
  syncJobId      String?

  @@unique([packageId, skuId])
  @@index([status])
  @@index([lastCheckedAt])
  @@index([orderMonth])
}

/// 历史月份调整项（退款/结算/扣费等后续变化）
model HistoricalAdjustment {
  id             String    @id @default(cuid())
  monthKey       String
  packageId      String?
  adjustmentType String
  amountCent     Int
  occurredAt     DateTime?
  description    String?
  orderMonth     String?
  refundMonth    String?
  syncJobId      String?
  createdAt      DateTime  @default(now())

  @@index([monthKey])
  @@index([packageId])
  @@index([createdAt])
}

/// 官方品质负反馈 / 品退明细（小红书商品品质负反馈接口）
model QualityBadCase {
  id                        String   @id @default(cuid())
  liveAccountId             String   @default("legacy")
  caseKey                   String
  packageId                 String
  sourceBizId               String?
  itemId                    String?
  itemName                  String?
  itemImage                 String?
  problemType               String   @default("品质问题")
  negativeReasonsJson       String   @default("[]")
  feedbackContent           String?
  feedbackTime              String?
  packagePayTime            String?
  rawJson                   String?
  matchedOrderNo            String?
  matchedOrderId            String?
  matchedAfterSaleId        String?
  matchedBuyerId            String?
  matchedBuyerNickname      String?
  matchedAnchorId           String?
  matchedAnchorName         String?
  afterSaleStatus           String?
  afterSaleReason           String?
  afterSaleRefundAmountCent Int      @default(0)
  afterSaleRefunded         Boolean  @default(false)
  source                    String   @default("official_quality_badcase")
  matchStatus               String   @default("unmatched")
  confidence                String   @default("high")
  syncedAt                  DateTime @default(now())
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([liveAccountId, caseKey])
  @@index([liveAccountId])
  @@index([packageId])
  @@index([sourceBizId])
  @@index([itemId])
  @@index([packagePayTime])
  @@index([feedbackTime])
  @@index([matchedAnchorId])
  @@index([matchedBuyerId])
}

model QualityBadCaseSyncMeta {
  id                    String    @id @default("default")
  source                String    @default("official_quality_badcase")
  windowDays            Int       @default(30)
  startTime             String?
  endTime               String?
  lastSyncedAt          DateTime?
  itemCount             Int       @default(0)
  caseCount             Int       @default(0)
  matchedOrderCount     Int       @default(0)
  matchedAfterSaleCount Int       @default(0)
  unmatchedCount        Int       @default(0)
  updatedAt             DateTime  @updatedAt
}

/// 售后按时间范围查询缓存（交叉印证，非品退主来源）
model XhsAfterSalesTimeSearchCache {
  id            String   @id @default(cuid())
  liveAccountId String   @default("legacy")
  returnId      String
  orderNo       String
  platformName  String   @default("merged")
  rangeKey      String
  rawJson      Json
  syncedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([liveAccountId, returnId, rangeKey])
  @@index([orderNo])
  @@index([rangeKey])
  @@index([liveAccountId])
}

/// 时间售后按店同步元数据（success_empty 也必须有行）
model XhsAfterSalesRangeSyncMeta {
  id            String    @id @default(cuid())
  rangeKey      String
  liveAccountId String
  platformName  String    @default("")
  /// success | success_empty | partial_success | failed | blocked | running
  status        String    @default("running")
  lastAttemptAt DateTime?
  lastSuccessAt DateTime?
  completedAt   DateTime?
  recordCount   Int       @default(0)
  orderCount    Int       @default(0)
  pageCount     Int       @default(0)
  errorType     String?
  errorMessage  String?
  sourceVersion String    @default("after-sales-range-v1")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([liveAccountId, rangeKey])
  @@index([rangeKey])
  @@index([status])
  @@index([lastSuccessAt])
}

/// 经营总览上月稳定快照（同步完成后写入，老板查看 lastMonth 时优先展示）
model OverviewMetricSnapshot {
  id                 String   @id @default(cuid())
  monthKey           String
  preset             String   @default("lastMonth")
  sourceSyncJobId    String?
  cacheBuiltAt       DateTime
  totalGmv           Float    @default(0)
  validSalesAmount   Float    @default(0)
  orderCount         Int      @default(0)
  refundAmount       Float    @default(0)
  qualityReturnCount Int      @default(0)
  dataJson           String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([monthKey, preset])
  @@index([cacheBuiltAt])
}

/// 买家排行全量客户画像缓存（与经营看板日期范围无关）
model BuyerRankingCache {
  id                      String   @id @default("default")
  itemsJson               String
  summaryJson             String
  blacklistedBuyerIdsJson String   @default("[]")
  orderCount              Int      @default(0)
  buyerCount              Int      @default(0)
  builtAt                 DateTime @default(now())
  updatedAt               DateTime @updatedAt
  lastTrigger             String?
}

/// 月度数据状态
model MonthlyDataStatus {
  monthKey                String    @id
  status                  String
  lastSyncedAt            DateTime?
  hasHistoricalAdjustment Boolean   @default(false)
  adjustmentAmountCent    Int       @default(0)
  grossProfitStability    String?
  updatedAt               DateTime  @updatedAt
  createdAt               DateTime  @default(now())
}

/// 运营报表：商品维度人工补充（不替代官方订单金额）
model ProductDimension {
  id          String   @id @default(cuid())
  productKey  String   @unique
  productCode String?
  productName String?
  skuName     String?
  ringSize    String?
  barType     String?
  productRole String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productCode])
}

/// 运营报表：每日/每周复盘笔记
model OpsReviewNote {
  id                  String   @id @default(cuid())
  reportDate          String
  reportType          String
  problemText         String   @default("")
  reasonText          String   @default("")
  trafficProductsJson String   @default("[]")
  mainProductsJson    String   @default("[]")
  profitProductsJson  String   @default("[]")
  scriptText          String   @default("")
  ownerName           String   @default("")
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([reportDate, reportType])
  @@index([reportType])
}

/// 运营报表：经营建议处理状态
model OperationsBusinessInsightAction {
  id             String   @id @default(cuid())
  insightId      String
  insightType    String
  entityType     String
  entityId       String?
  entityName     String
  rangeStartDate String
  rangeEndDate   String
  scope          String
  status         String   @default("pending")
  note           String?
  reviewResult   String?
  remindTomorrow Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([insightId, rangeStartDate, rangeEndDate, scope])
  @@index([rangeStartDate, rangeEndDate, scope])
}

/// 好评中心：店铺评分与统计快照（按 shopKey 缓存）
model GoodReviewShopSnapshot {
  id                      String    @id @default(cuid())
  shopKey                 String    @unique
  shopName                String
  shopScore               Float?
  totalReviewCount        Int       @default(0)
  goodReviewCount         Int       @default(0)
  mediumReviewCount       Int       @default(0)
  badReviewCount          Int       @default(0)
  withImageCount          Int       @default(0)
  withTextCount           Int       @default(0)
  unrepliedCount          Int       @default(0)
  repliedCount            Int       @default(0)
  pendingInteractionCount Int       @default(0)
  pendingBadReviewCount   Int       @default(0)
  scoreRawJson            String?
  countDetailRawJson      String?
  overviewRawJson         String?
  syncedAt                DateTime?
  updatedAt               DateTime  @updatedAt
  createdAt               DateTime  @default(now())
}

/// 好评中心：单条评价缓存
model GoodReview {
  id               String    @id @default(cuid())
  shopKey          String
  dedupeKey        String
  reviewId         String?
  orderId          String?
  itemId           String?
  skuId            String?
  itemName         String?
  itemImage        String?
  itemPriceCent    Int?
  itemQuantity     Int?
  productScore     Float?
  serviceScore     Float?
  logisticsScore   Float?
  reviewText       String?
  reviewImagesJson String    @default("[]")
  reviewTagsJson   String    @default("[]")
  materialTagsJson String    @default("[]")
  isAnonymous      Boolean   @default(false)
  likeCount        Int       @default(0)
  replyCount       Int       @default(0)
  reviewTime       DateTime?
  reviewTimeText   String?
  rawJson          String?
  syncedAt         DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  @@unique([shopKey, dedupeKey])
  @@index([shopKey])
  @@index([reviewTime])
  @@index([reviewId])
}

/// 好评中心：全局同步元数据
model GoodReviewSyncMeta {
  id           String    @id @default("default")
  lastSyncedAt DateTime?
  updatedAt    DateTime  @updatedAt
}

/// 主播默认排班模板（种子配置，可被运营扩展）
model AnchorScheduleTemplate {
  id            String   @id @default(cuid())
  /** 稳定关联 Anchor.id；匹配优先用此字段 */
  anchorId      String?
  /** 姓名快照（改名后历史展示）；正式匹配优先 anchorId */
  anchorName    String
  shopName      String
  liveRoomName  String
  startTime     String
  endTime       String
  effectiveFrom String?
  effectiveTo   String?
  enabled       Boolean  @default(true)
  sortOrder     Int      @default(0)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([enabled, sortOrder])
  @@index([anchorId])
}

/// 每日主播排班（手动覆盖或生成的默认排班）
model AnchorDailySchedule {
  id           String    @id @default(cuid())
  scheduleDate String
  /** 稳定关联 Anchor.id；匹配优先用此字段 */
  anchorId     String?
  /** 姓名快照；正式匹配优先 anchorId */
  anchorName   String
  shopName     String
  liveRoomName String
  startAt      DateTime
  endAt        DateTime
  source       String    @default("manual")
  enabled      Boolean   @default(true)
  locked       Boolean   @default(false)
  confirmed    Boolean   @default(false)
  confirmedAt  DateTime?
  confirmedBy  String?
  confirmNote  String?
  note         String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([scheduleDate])
  @@index([scheduleDate, enabled])
  @@index([scheduleDate, confirmed])
  @@index([anchorId])
}

/// 日报发货前照片（按日期归档，文件存 data 目录）
model DailyReportImage {
  id           String   @id @default(cuid())
  reportDate   String
  filePath     String
  publicUrl    String
  originalName String
  mimeType     String
  size         Int
  caption      String?
  sortOrder    Int      @default(0)
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@index([reportDate, sortOrder])
}

/// 未归属订单手动指定主播（按 P 单号持久化）
/// @deprecated 新写入请用 OrderAttributionDisposition；本表保留供历史兼容读取
model OrderAnchorManualOverride {
  id          String   @id @default(cuid())
  orderKey    String   @unique
  anchorName  String
  anchorId    String?
  assignedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([anchorName])
}

/// 订单归属人工处置（指定主播 / 确认非直播成交），按 P 单号持久化
model OrderAttributionDisposition {
  id                String    @id @default(cuid())
  orderKey          String    @unique
  /// anchor | non_live（pending 不落库）
  disposition       String
  anchorName        String?
  anchorId          String?
  /// offline_communication | private_domain | customer_service | owner_sale | other
  nonLiveReason     String?
  nonLiveReasonText String?
  confirmedBy       String?
  confirmedAt       DateTime?
  confirmNote       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([disposition])
  @@index([confirmedAt])
}

/// 订单归属处置操作记录
model OrderAttributionDispositionLog {
  id        String   @id @default(cuid())
  orderKey  String
  action    String
  fromJson  String?
  toJson    String?
  operator  String?
  note      String?
  createdAt DateTime @default(now())

  @@index([orderKey, createdAt])
  @@index([createdAt])
}

/// 线下成交台账（无平台 P 单也可录入；计入支付金额/主播 GMV）
model OfflineDeal {
  id            String    @id @default(cuid())
  /** 系统唯一成交编号，如 OFF-20260714-xxxx */
  dealKey       String    @unique
  /** 可选外部唯一号（防重复提交）；不可与已有线上 P 单号冲突 */
  externalKey   String?   @unique
  amountCent    Int
  refundCent    Int       @default(0)
  dealAt        DateTime
  /** draft | confirmed | cancelled | voided */
  status        String    @default("confirmed")
  anchorId      String?
  anchorName    String?
  customerLabel String?
  note          String?
  createdBy     String?
  updatedBy     String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([dealAt, status])
  @@index([anchorId])
  @@index([status])
  @@index([deletedAt])
}

model OfflineDealAuditLog {
  id             String   @id @default(cuid())
  dealId         String
  dealKey        String
  action         String
  beforeJson     String?
  afterJson      String?
  beforeAnchorId String?
  afterAnchorId  String?
  operator       String?
  reason         String?
  createdAt      DateTime @default(now())

  @@index([dealId, createdAt])
  @@index([dealKey])
  @@index([createdAt])
}

/// 老板看板：店铺资金快照（金额均为分）

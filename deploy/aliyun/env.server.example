# 复制到服务器 apps/server/.env（勿提交 Git）
# 公网 IP 部署示例 — 8.137.126.18

NODE_ENV=production
HOST=127.0.0.1
PORT=4723

DATABASE_URL="file:../data/app.db"

SESSION_SECRET=请替换成随机长字符串
COOKIE_ENCRYPTION_KEY=请替换成32位以上随机字符串

WEB_ORIGIN=http://8.137.126.18,http://8.137.126.18/zhubofenxi,http://xiangyuzhubao.xyz,http://www.xiangyuzhubao.xyz
CORS_ORIGIN=http://8.137.126.18,http://8.137.126.18/zhubofenxi,http://xiangyuzhubao.xyz,http://www.xiangyuzhubao.xyz
# 生产入口子路径（与 Nginx /zhubofenxi/ 一致；构建时同步 VITE_BASE_PATH=/zhubofenxi/）
WEB_BASE_PATH=/zhubofenxi
COOKIE_SECURE=false

# 生产环境须登录；本地开发可设 AUTH_MODE=local
AUTH_MODE=session
AUTH_ALLOW_REGISTER=true

DOWNLOAD_DIR=./data/downloads
MAX_DOWNLOAD_SIZE_MB=100

# Linux 签名 Python（先运行 scripts/install-xhs-signer.sh）
XHS_SIGNER_ENABLED=true
XHS_SIGNER_PYTHON=tools/xhs_signer/.venv/bin/python

# 可选：系统设置未填 sellerId 时使用
# XHS_SELLER_ID=

# 千帆 Cookie 本地兜底：系统设置 → 直播号（加密存 SQLite）；可选 .env 变量见 apps/server/.env.example

# 总控台 Cookie 中心（优先从此读取四店千帆 Cookie）
CONTROL_SERVER_URL=http://8.137.126.18/control
CONTROL_SERVICE_TOKEN=

# 四店 Cookie 批量上传（POST /api/shop-cookies/update）
SHOP_COOKIE_UPLOAD_TOKEN=请替换成随机长字符串

# 维护工具生产环境默认关闭
# ENABLE_MAINTENANCE_TOOLS=false

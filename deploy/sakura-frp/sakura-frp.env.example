# Sakura Frp 访问密钥（从 Sakura Frp 管理面板 → 查看访问密钥 复制）
# 注意：这是客户端专用密钥，不是网站登录密码
SAKURA_FRP_TOKEN=

# 隧道 ID（创建 TCP 隧道后，在隧道列表或「配置文件」里可见，纯数字）
SAKURA_FRP_TUNNEL_ID=

# 远程节点域名（隧道创建成功后，面板会显示，例如 xxx.natfrp.cloud 或节点域名）
SAKURA_FRP_REMOTE_HOST=

# 远程端口（TCP 隧道的外网端口，面板分配或您手动选择）
SAKURA_FRP_REMOTE_PORT=

# 本地经营看板地址（一般不用改）
LOCAL_HOST=127.0.0.1
LOCAL_PORT=4723

# frpc 可执行文件路径（相对项目根目录；留空则自动查找）
# FRPC_PATH=tools/sakura-frp/frpc.exe

# 可选：若面板复制的是完整启动参数（如 -f token:id），可填这里并留空 TUNNEL_ID
# SAKURA_FRP_EXTRA_ARGS=

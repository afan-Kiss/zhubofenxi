{
  "name": "live-business-web",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/server"
  ],
  "scripts": {
    "dev": "concurrently -k --names web,server -c \"#ff2e63,#0ea5e9\" \"npm run dev -w @live/web\" \"npm run dev -w @live/server\"",
    "dev:web": "npm run dev -w @live/web",
    "dev:server": "npm run dev -w @live/server",
    "dev:desktop": "cross-env NODE_ENV=development concurrently --kill-others-on-fail -n \"VITE,MAIN,ELECTRON\" -c \"#ff2e63,#0ea5e9,#a78bfa\" \"vite\" \"tsc -p src/main/tsconfig.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 file:dist/main/main.js && electron .\"",
    "build": "npm run build:web && npm run build:server",
    "build:web": "npm run build -w @live/web",
    "build:server": "npm run build -w @live/server",
    "prestart:server": "node scripts/prestart-web-dist.cjs",
    "start:server": "cross-env NODE_ENV=production npm run start -w @live/server",
    "start": "npm run start:server",
    "prisma:generate": "npm run db:generate -w @live/server",
    "prisma:migrate": "npm run db:migrate:deploy -w @live/server",
    "fix:admin-password-flag": "tsx apps/server/scripts/fix-admin-password-flag.ts",
    "accept:gmv": "tsx apps/server/scripts/gmv-acceptance.ts",
    "accept:gmv:fast": "cross-env GMV_ACCEPT_SKIP_SYNC=1 tsx apps/server/scripts/gmv-acceptance.ts",
    "accept:buyer-amount": "tsx apps/server/scripts/buyer-amount-consistency-acceptance.ts",
    "accept:buyer-identity": "tsx apps/server/scripts/buyer-identity-acceptance.ts",
    "accept:after-sales-fetch": "tsx apps/server/scripts/after-sales-fetch-decision-acceptance.ts",
    "accept:after-sales-pending": "tsx apps/server/scripts/after-sales-pending-state-acceptance.ts",
    "accept:anchor-metrics-fix": "tsx apps/server/scripts/anchor-metrics-fix-acceptance.ts",
    "accept:operations-report": "tsx apps/server/scripts/operations-report-acceptance.ts",
    "accept:operations-report-smoke": "tsx apps/server/scripts/operations-report-smoke.ts",
    "accept:operations-report-gray-check": "tsx apps/server/scripts/operations-report-gray-check.ts",
    "accept:metrics-exclusion": "tsx apps/server/scripts/metrics-exclusion-acceptance.ts",
    "accept:quality-refund": "tsx apps/server/scripts/dev/quality-refund-acceptance.ts",
    "check:business": "tsx apps/server/scripts/acceptance/check-business-rules.ts",
    "check:copy": "tsx apps/server/scripts/acceptance/check-copy-rules.ts",
    "check:finance": "tsx apps/server/scripts/acceptance/check-no-finance-modules.ts",
    "check:money": "tsx apps/server/scripts/acceptance/check-money-format.ts",
    "check:quality-return": "tsx apps/server/scripts/acceptance/check-quality-return.ts",
    "check:deprecated-api": "tsx apps/server/scripts/acceptance/check-deprecated-api.ts",
    "acceptance": "npm run check:business && npm run check:copy && npm run check:finance && npm run check:money && npm run check:quality-return && npm run check:deprecated-api && npm run build",
    "test:metrics": "tsx apps/server/scripts/metrics-acceptance/index.ts",
    "test:metrics:golden": "tsx apps/server/scripts/metrics-acceptance/golden-index.ts",
    "debug:metrics:20260528": "tsx apps/server/scripts/metrics-acceptance/debug-2026-05-28.ts",
    "debug:sync": "tsx apps/server/scripts/debug-sync.ts",
    "test:sync": "tsx apps/server/scripts/sync-acceptance/index.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "verify": "npm run acceptance && npm run test:e2e",
    "verify:full": "npm run acceptance && npm run test:e2e && npm run test:metrics",
    "verify:golden": "npm run test:metrics:golden",
    "diagnose:buyer-after-sales": "tsx apps/server/scripts/buyer-after-sales-sync-diagnose.ts",
    "db:migrate": "npm run db:migrate -w @live/server",
    "db:generate": "npm run db:generate -w @live/server",
    "db:push": "npm run db:push -w @live/server",
    "deploy:check": "node scripts/deploy-check.cjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3"
  }
}
